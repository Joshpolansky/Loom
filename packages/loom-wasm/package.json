{
  "name": "@joshpolansky/loom-wasm",
  "version": "0.3.0",
  "description": "Boot the Loom runtime in-browser via WebAssembly and get a lux-react-compatible machine connection.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
